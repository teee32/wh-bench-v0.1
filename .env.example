# LLM Provider 配置
# 兼容 OpenAI API 格式，foxnio 网关同时代理 OpenAI 和 Anthropic 模型

# 蒸馏 / GPT 评审（gpt-* 家族）
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.foxnio.com/v1
OPENAI_MODEL_DISTILL=gpt-5.4-mini
OPENAI_MODEL_JUDGE=gpt-5.5

# Claude 评审（独立 base_url）
FOXNIO_OPUS_API_KEY=sk-xxx
FOXNIO_OPUS_BASE_URL=https://sub.foxnio.com/v1
CLAUDE_MODEL_JUDGE=claude-sonnet-4-6

# 蒸馏配置
DISTILL_MAX_CHUNKS_PER_DOC=8
DISTILL_MAX_QA_PER_CHUNK=3
DISTILL_TEMPERATURE=0.3
DISTILL_MAX_PARALLEL=4

# 评测 Web（可选）
REVIEW_PORT=7860

# HuggingFace
HF_REPO_ID=teee32/wh-bench-v0.1
# HF_TOKEN 留空则用 ~/.cache/huggingface/token

# GitHub
GITHUB_REPO=teee32/wh-bench-v0.1
